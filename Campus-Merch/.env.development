# 默认走本地 mock，与现有页面数据结构一致
VITE_USE_MOCK=true
# 浏览器请求前缀；开发时由 Vite 代理到 VITE_API_PROXY_TARGET
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://127.0.0.1:8080
# 对接真实后端时改为 false，并保证后端返回 { code, message?, data }，成功码见下行
# VITE_USE_MOCK=false
# 若后端用 200 表示成功：VITE_API_SUCCESS_CODES=0,200
VITE_API_SUCCESS_CODES=0,200
